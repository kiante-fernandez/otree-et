# Copy to `.env` (or export these in your shell / hosting platform's UI)
# before running otree in production. The `.env` file is gitignored.

# Switch oTree out of debug mode. Required for any non-local deployment.
OTREE_PRODUCTION=1

# Cookie-signing secret. Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
# If unset, settings.py generates a random key per process — fine for devserver,
# but participants get logged out on every restart in production.
OTREE_SECRET_KEY=

# Password for the /admin interface. Username is "admin".
OTREE_ADMIN_PASSWORD=

# Postgres connection string. SQLite is acceptable for devserver only.
# Format: postgres://user:password@host:5432/dbname
DATABASE_URL=

# Lock down participant URLs. Use STUDY for paid studies, DEMO for open access.
OTREE_AUTH_LEVEL=STUDY
