 // @ts-ignore
 import WebEyeTrackWorker from "worker-loader?inline=no-fallback!./WebEyeTrackWorker.ts";
+
+export interface WebEyeTrackProxyOptions {
+  /** Override where the base gaze model is fetched from. */
+  modelUrl?: string;
+  /**
+   * Restore, and later persist, a personalised model under this key. Model
+   * adaptation happens in the worker and dies with it, so without a key a
+   * calibration cannot outlive the page it was performed on.
+   */
+  calibrationKey?: string;
+  /** Size of the calibration support set. Defaults to 5. */
+  maxPoints?: number;
+  /** Seconds before click-derived calibration points expire. Defaults to 60. */
+  clickTTL?: number;
+}
+
 export default class WebEyeTrackProxy {
   private worker: Worker;
 
   public status: 'idle' | 'inference' | 'calib' = 'idle';
 
-  constructor(webcamClient: WebcamClient) {
+  constructor(webcamClient: WebcamClient, options: WebEyeTrackProxyOptions = {}) {
 
     // Initialize the WebEyeTrackWorker
     this.worker = new WebEyeTrackWorker();
@@ -45,6 +61,10 @@ export default class WebEyeTrackProxy {
           this.status = mess.data.status;
           break;
 
+        case 'calibrationSaved':
