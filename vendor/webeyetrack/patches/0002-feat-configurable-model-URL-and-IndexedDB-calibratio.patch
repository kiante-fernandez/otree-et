--- a/src/BlazeGaze.ts
+++ b/src/BlazeGaze.ts
@@ -11,8 +11,39 @@ export default class BlazeGaze {
         // Optionally trigger model load in constructor
     }
 
-    async loadModel(): Promise<void> {
-        const path = `${self.location.origin}/web/model.json`;
+    /**
+     * Load the gaze model.
+     *
+     * @param modelUrl Where to fetch the base model from. Defaults to
+     *   `${self.location.origin}/web/model.json`, as before. Host applications
+     *   that serve their static files from another prefix can override it
+     *   rather than proxying that one path.
+     * @param calibrationKey When set, a model previously stored by
+     *   `saveCalibration()` under `indexeddb://<calibrationKey>` is restored
+     *   instead of the base model. `adapt()` personalises the weights in place,
+     *   so this is what lets a calibration performed on one page apply to a
+     *   later page load — each page otherwise starts from the base model.
+     */
+    async loadModel(modelUrl?: string, calibrationKey?: string): Promise<void> {
+        if (calibrationKey) {
+            try {
+                this.model = await tf.loadLayersModel(`indexeddb://${calibrationKey}`);
+                console.log(`✅ BlazeGaze restored a calibrated model from indexeddb://${calibrationKey}`);
+                this.model.getLayer('cnn_encoder').trainable = false;
+                return;
+            } catch (error) {
+                console.warn(
+                    `No stored calibration at indexeddb://${calibrationKey}; falling back to the base model.`
+                );
+            }
+        }
+
+        // Resolve against the origin. This code runs inside a Web Worker built
+        // from a blob: URL, which has no usable base URL, so a root-relative
+        // path such as "/static/web/model.json" cannot be fetched as given.
+        const path = modelUrl
+            ? new URL(modelUrl, self.location.origin).toString()
+            : `${self.location.origin}/web/model.json`;
         try {
             // Load model from local directory (adjust path if needed)
             this.model = await tf.loadLayersModel(path);
@@ -22,11 +53,22 @@ export default class BlazeGaze {
             console.error(error);
             throw error;
         }
-        
+
         // Freeze the ``cnn_model`` layers but keep the gaze_MLP trainable
         this.model.getLayer('cnn_encoder').trainable = false;
     }
 
+    /**
+     * Persist the current, already-adapted model so a later page load can
+     * restore it via `loadModel(modelUrl, calibrationKey)`.
+     */
+    async saveCalibration(calibrationKey: string): Promise<void> {
+        if (!this.model) {
+            throw new Error('Model not loaded. Call loadModel() first.');
+        }
+        await this.model.save(`indexeddb://${calibrationKey}`);
+    }
+
     predict(image: tf.Tensor, head_vector: tf.Tensor, face_origin_3d: tf.Tensor): tf.Tensor {
