+  /**
+   * Adapt the model to a known gaze target, in normalized coordinates.
+   *
+   * This is the deliberate counterpart to handleClick(): a calibration routine
+   * knows the participant is looking at the point it just asked them to click,
+   * so the debounce and proximity heuristics that handleClick() applies to
+   * incidental clicks are not wanted here. They are also actively harmful for
+   * calibration -- the debounce is rolling (an ignored click resets the timer),
+   * so a run of dots clicked less than a second apart adapts only once.
+   *
+   * @returns true if the model was adapted. False means there was no usable
+   *   gaze result to pair with the target -- typically no face was detected --
+   *   and the caller should ask the participant to reposition rather than
+   *   silently record an uncalibrated point.
+   */
+  calibrate(x: number, y: number): boolean {
     this.latestMouseClick = { x, y, timestamp: Date.now() };
 
