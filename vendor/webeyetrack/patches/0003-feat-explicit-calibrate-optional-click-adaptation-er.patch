+   * is durable. Pass the same key to a later WebEyeTrackProxy to restore it.
    */
   saveCalibration(calibrationKey: string) {
     this.worker.postMessage({ type: 'saveCalibration', payload: { calibrationKey } });
   }
 
+  /** Release the worker and the click listener. */
