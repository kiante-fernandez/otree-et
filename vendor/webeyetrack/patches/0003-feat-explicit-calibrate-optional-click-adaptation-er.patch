+  /**
+   * Turn incidental click-driven adaptation on or off at any time. A
+   * calibration routine typically enables it (or uses `calibrate()` directly)
+   * and then disables it before measurement begins.
+   */
+  setAdaptOnClick(enabled: boolean) {
+    if (enabled && !this.clickListener) {
+      this.clickListener = (e: MouseEvent) => {
+        // Convert px to normalized coordinates
+        const normX = (e.clientX / window.innerWidth) - 0.5;
+        const normY = (e.clientY / window.innerHeight) - 0.5;
+        this.worker.postMessage({ type: 'click', payload: { x: normX, y: normY }});
+      };
+      window.addEventListener('click', this.clickListener);
+    } else if (!enabled && this.clickListener) {
+      window.removeEventListener('click', this.clickListener);
+      this.clickListener = null;
+    }
+  }
+
+  /**
+   * Adapt to a known gaze target, in normalized coordinates ([-0.5, 0.5]).
+   * Unlike an incidental click this is not debounced, so a calibration routine
+   * can present points as quickly as it likes. `onCalibrationPoint` reports
+   * whether the point was actually used.
+   */
+  calibrate(normX: number, normY: number) {
+    this.worker.postMessage({ type: 'calibrate', payload: { x: normX, y: normY } });
   }
 
